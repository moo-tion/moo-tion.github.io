---
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="#home" id="moo-mode-trigger" class="flex items-center gap-2.5 group" aria-label="Moo-tion home">
        <img 
          src="/mootion_logo_square.png" 
          alt="Moo-tion Logo" 
          class="cow-bouncy-icon h-9 w-9 rounded-xl object-contain group-hover:scale-105 transition-transform"
        />
        <span class="text-lg font-bold text-text-primary">Moo-tion</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-1">
        <a href="#home" class="px-3.5 py-2 text-sm font-medium text-text-secondary hover:text-primary rounded-lg hover:bg-white/5 transition-all duration-200" data-i18n="nav.home">Ana Sayfa</a>
        <a href="#features" class="px-3.5 py-2 text-sm font-medium text-text-secondary hover:text-primary rounded-lg hover:bg-white/5 transition-all duration-200" data-i18n="nav.features">Özellikler</a>
        <a href="#demo" class="px-3.5 py-2 text-sm font-medium text-text-secondary hover:text-primary rounded-lg hover:bg-white/5 transition-all duration-200" data-i18n="nav.demo">Demo</a>
        <a href="#reports" class="px-3.5 py-2 text-sm font-medium text-text-secondary hover:text-primary rounded-lg hover:bg-white/5 transition-all duration-200" data-i18n="nav.reports">Raporlar</a>
        <a href="#team" class="px-3.5 py-2 text-sm font-medium text-text-secondary hover:text-primary rounded-lg hover:bg-white/5 transition-all duration-200" data-i18n="nav.team">Ekip</a>
        <a href="#architecture" class="px-3.5 py-2 text-sm font-medium text-text-secondary hover:text-primary rounded-lg hover:bg-white/5 transition-all duration-200" data-i18n="nav.architecture">Mimari</a>
        <a
          href="https://github.com/moo-tion"
          target="_blank"
          rel="noopener"
          class="cow-button ml-3 flex items-center gap-2 rounded-full px-4 py-2 text-sm font-semibold transition-all duration-200"
        >
          <img src="/cows/cow_icon.png" alt="" class="h-5 w-5 rounded-full bg-white/85 p-0.5" />
          GitHub
        </a>
      </nav>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden flex items-center justify-center h-10 w-10 rounded-xl text-text-secondary hover:text-text-primary hover:bg-white/5 transition-colors"
        aria-label="Menüyü aç/kapat"
        aria-expanded="false"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-bg-primary/95 backdrop-blur-xl">
    <nav class="mx-auto max-w-7xl px-4 py-4 flex flex-col gap-1">
      <a href="#home" class="mobile-nav-link px-4 py-3 text-sm font-medium text-text-secondary hover:text-primary rounded-xl hover:bg-white/5 transition-all duration-200" data-i18n="nav.home">Ana Sayfa</a>
      <a href="#features" class="mobile-nav-link px-4 py-3 text-sm font-medium text-text-secondary hover:text-primary rounded-xl hover:bg-white/5 transition-all duration-200" data-i18n="nav.features">Özellikler</a>
      <a href="#demo" class="mobile-nav-link px-4 py-3 text-sm font-medium text-text-secondary hover:text-primary rounded-xl hover:bg-white/5 transition-all duration-200" data-i18n="nav.demo">Demo</a>
      <a href="#reports" class="mobile-nav-link px-4 py-3 text-sm font-medium text-text-secondary hover:text-primary rounded-xl hover:bg-white/5 transition-all duration-200" data-i18n="nav.reports">Raporlar</a>
      <a href="#team" class="mobile-nav-link px-4 py-3 text-sm font-medium text-text-secondary hover:text-primary rounded-xl hover:bg-white/5 transition-all duration-200" data-i18n="nav.team">Ekip</a>
      <a href="#architecture" class="mobile-nav-link px-4 py-3 text-sm font-medium text-text-secondary hover:text-primary rounded-xl hover:bg-white/5 transition-all duration-200" data-i18n="nav.architecture">Mimari</a>
      <a
        href="https://github.com/moo-tion"
        target="_blank"
        rel="noopener"
        class="cow-button mt-2 flex items-center gap-2 rounded-full px-4 py-3 text-sm font-semibold transition-all"
      >
        <img src="/cows/cow_icon.png" alt="" class="h-5 w-5 rounded-full bg-white/85 p-0.5" />
        GitHub
      </a>
    </nav>
  </div>
</header>

<div id="moo-mode-banner" class="moo-mode-banner" role="status" aria-live="polite">
  <img src="/cows/cow_icon.png" alt="" />
  <span>Moo mode activated</span>
</div>

<script>
  // i18n translations for Astro components
  const navTranslations: Record<string, Record<string, string>> = {
    tr: { 'nav.home': 'Ana Sayfa', 'nav.features': 'Özellikler', 'nav.demo': 'Demo', 'nav.reports': 'Raporlar', 'nav.team': 'Ekip', 'nav.architecture': 'Mimari' },
    en: { 'nav.home': 'Home', 'nav.features': 'Features', 'nav.demo': 'Demo', 'nav.reports': 'Reports', 'nav.team': 'Team', 'nav.architecture': 'Architecture' },
  };

  function updateNavLanguage(locale: string) {
    const trans = navTranslations[locale] || navTranslations.tr;
    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n');
      if (key && trans[key]) {
        el.textContent = trans[key];
      }
    });
  }

  // Listen for language change events from React
  window.addEventListener('locale-change', ((e: CustomEvent) => {
    updateNavLanguage(e.detail);
  }) as EventListener);

  // Initial locale from localStorage
  const savedLang = localStorage.getItem('mootion-lang') || 'tr';
  updateNavLanguage(savedLang);

  // Navbar background on scroll
  const header = document.getElementById('site-header');
  const scrollHandler = () => {
    if (!header) return;
    if (window.scrollY > 50) {
      header.classList.add('bg-bg-primary/80', 'backdrop-blur-xl', 'border-b', 'border-border');
    } else {
      header.classList.remove('bg-bg-primary/80', 'backdrop-blur-xl', 'border-b', 'border-border');
    }
  };
  window.addEventListener('scroll', scrollHandler);
  scrollHandler();

  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  if (menuBtn && mobileMenu) {
    const hamburgerSvg = `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"/></svg>`;
    const closeSvg = `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>`;

    menuBtn.addEventListener('click', () => {
      const expanded = menuBtn.getAttribute('aria-expanded') === 'true';
      menuBtn.setAttribute('aria-expanded', String(!expanded));
      mobileMenu.classList.toggle('hidden');
      menuBtn.innerHTML = expanded ? hamburgerSvg : closeSvg;
    });

    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        menuBtn.setAttribute('aria-expanded', 'false');
        mobileMenu.classList.add('hidden');
        menuBtn.innerHTML = hamburgerSvg;
      });
    });
  }

  // Moo mode easter egg: click the logo five times.
  const mooModeTrigger = document.getElementById('moo-mode-trigger');
  const mooModeBanner = document.getElementById('moo-mode-banner');
  let mooClicks = 0;
  let mooResetTimer: number | undefined;
  let mooHideTimer: number | undefined;

  mooModeTrigger?.addEventListener('click', () => {
    mooClicks += 1;
    window.clearTimeout(mooResetTimer);
    mooResetTimer = window.setTimeout(() => {
      mooClicks = 0;
    }, 1600);

    if (mooClicks < 5) return;

    mooClicks = 0;
    document.body.classList.toggle('moo-mode');
    if (!mooModeBanner) return;

    const active = document.body.classList.contains('moo-mode');
    mooModeBanner.querySelector('span')!.textContent = active ? 'Moo mode activated' : 'Moo mode resting';
    mooModeBanner.classList.add('is-visible');
    window.clearTimeout(mooHideTimer);
    mooHideTimer = window.setTimeout(() => {
      mooModeBanner.classList.remove('is-visible');
    }, 2200);
  });
</script>
