---
const currentYear = new Date().getFullYear();
const lastUpdatedISO = new Date().toISOString();
---

<footer class="relative border-t border-border">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
      <div class="flex flex-col items-center gap-2 sm:items-start">
        <a href="#home" class="flex items-center gap-2 group">
          <img
            src="/mootion_logo_square.png"
            alt="Moo-tion Logo"
            class="h-7 w-7 rounded-lg object-contain"
          />
          <span class="text-sm font-bold text-text-primary">Moo-tion</span>
        </a>
        <p class="text-center text-xs text-text-muted sm:text-left">
          <span data-i18n="footer.university">Bilkent Üniversitesi - Bilgisayar Mühendisliği Bölümü</span>
        </p>
      </div>

      <div class="text-center text-xs text-text-muted sm:text-right">
        <p>© {currentYear} Moo-tion</p>
        <p class="mt-0.5">
          <span data-i18n="footer.lastUpdated">Son güncelleme</span>:
          <span id="footer-last-updated-date" data-date={lastUpdatedISO}></span>
        </p>
      </div>
    </div>
  </div>

  <div class="walking-cow-track" aria-hidden="true">
    <img src="/cows/cow_figure_black_white.svg" alt="" class="walking-cow" />
  </div>
</footer>

<script>
  const footerTranslations: Record<string, Record<string, string>> = {
    tr: {
      'footer.university': 'Bilkent Üniversitesi - Bilgisayar Mühendisliği Bölümü',
      'footer.lastUpdated': 'Son güncelleme',
    },
    en: {
      'footer.university': 'Bilkent University - Department of Computer Engineering',
      'footer.lastUpdated': 'Last updated',
    },
  };

  function updateFooterLanguage(locale: string) {
    const trans = footerTranslations[locale] || footerTranslations.tr;
    document.querySelectorAll('[data-i18n^="footer."]').forEach((el) => {
      const key = el.getAttribute('data-i18n');
      if (key && trans[key]) {
        el.textContent = trans[key];
      }
    });

    const dateEl = document.getElementById('footer-last-updated-date');
    const isoDate = dateEl?.getAttribute('data-date');
    if (dateEl && isoDate) {
      dateEl.textContent = new Date(isoDate).toLocaleDateString(locale === 'en' ? 'en-US' : 'tr-TR', {
        day: 'numeric',
        month: 'long',
        year: 'numeric',
      });
    }
  }

  window.addEventListener('locale-change', ((e: CustomEvent) => {
    updateFooterLanguage(e.detail);
  }) as EventListener);

  const savedLang = localStorage.getItem('mootion-lang') || 'tr';
  updateFooterLanguage(savedLang);
</script>
