---
const currentYear = new Date().getFullYear();
const lastUpdatedISO = new Date().toISOString();
---

<footer class="relative border-t border-border">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <!-- Logo + Info -->
      <div class="flex flex-col items-center sm:items-start gap-2">
        <a href="#home" class="flex items-center gap-2 group">
          <img 
            src="/mootion_logo_square.png" 
            alt="Moo-tion Logo" 
            class="h-7 w-7 rounded-lg object-contain"
          />
          <span class="text-sm font-bold text-text-primary">Moo-tion</span>
        </a>
        <p class="text-xs text-text-muted text-center sm:text-left">
          <span data-i18n="footer.project">Senior Year Project</span><br />
          <span data-i18n="footer.university">Bilkent Üniversitesi — Bilgisayar Mühendisliği Bölümü</span>
        </p>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6">
        <a href="https://github.com/moo-tion" target="_blank" rel="noopener" class="text-text-muted hover:text-primary transition-colors" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 .5C5.73.5.77 5.46.77 11.74c0 4.92 3.19 9.1 7.62 10.57.56.1.77-.24.77-.54v-2c-3.1.67-3.76-1.34-3.76-1.34-.51-1.28-1.25-1.62-1.25-1.62-1.02-.7.08-.68.08-.68 1.12.08 1.7 1.15 1.7 1.15 1 .1.77 2.1 2.86 1.53.1-.75.39-1.27.7-1.56-2.48-.28-5.08-1.24-5.08-5.51 0-1.22.43-2.22 1.14-3-.11-.28-.5-1.42.11-2.95 0 0 .95-.3 3.1 1.15.9-.25 1.86-.38 2.82-.39.96.01 1.92.14 2.82.39 2.15-1.45 3.1-1.15 3.1-1.15.61 1.53.22 2.67.11 2.95.71.78 1.14 1.78 1.14 3 0 4.28-2.61 5.22-5.1 5.49.4.35.75 1.04.75 2.1v3.11c0 .3.21.65.78.54 4.42-1.47 7.61-5.65 7.61-10.57C23.22 5.46 18.26.5 12 .5Z"/>
          </svg>
        </a>
        <span class="text-xs text-text-muted" data-i18n="footer.course">
          Senior Year Project
        </span>
      </div>

      <!-- Last updated -->
      <div class="text-xs text-text-muted text-center sm:text-right">
        <p>© {currentYear} Moo-tion</p>
        <p class="mt-0.5">
          <span data-i18n="footer.lastUpdated">Son güncelleme</span>:
          <span id="footer-last-updated-date" data-date={lastUpdatedISO}></span>
        </p>
      </div>
    </div>
  </div>

  <div class="walking-cow-track" aria-hidden="true">
    <img src="/cows/cow_figure_black_white.svg" alt="" class="walking-cow" />
  </div>
</footer>

<script>
  const footerTranslations: Record<string, Record<string, string>> = {
    tr: {
      'footer.project': 'Senior Year Project',
      'footer.university': 'Bilkent Üniversitesi — Bilgisayar Mühendisliği Bölümü',
      'footer.course': 'Senior Year Project',
      'footer.lastUpdated': 'Son güncelleme',
    },
    en: {
      'footer.project': 'Senior Year Project',
      'footer.university': 'Bilkent University — Computer Science Department',
      'footer.course': 'Senior Year Project',
      'footer.lastUpdated': 'Last updated',
    },
  };

  function updateFooterLanguage(locale: string) {
    const trans = footerTranslations[locale] || footerTranslations.tr;
    document.querySelectorAll('[data-i18n^="footer."]').forEach((el) => {
      const key = el.getAttribute('data-i18n');
      if (key && trans[key]) {
        el.textContent = trans[key];
      }
    });

    const dateEl = document.getElementById('footer-last-updated-date');
    const isoDate = dateEl?.getAttribute('data-date');
    if (dateEl && isoDate) {
      dateEl.textContent = new Date(isoDate).toLocaleDateString(locale === 'en' ? 'en-US' : 'tr-TR', {
        day: 'numeric',
        month: 'long',
        year: 'numeric',
      });
    }
  }

  window.addEventListener('locale-change', ((e: CustomEvent) => {
    updateFooterLanguage(e.detail);
  }) as EventListener);

  const savedLang = localStorage.getItem('mootion-lang') || 'tr';
  updateFooterLanguage(savedLang);
</script>
