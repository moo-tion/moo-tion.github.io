---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Moo-tion — Akıllı Çiftçilik için Yapay Zeka Destekli Kızgınlık Tespiti',
  description = 'Moo-tion; kızgınlık tespiti, doğum tahmini ve inek aktivite takibi yapan bilgisayarlı görü tabanlı bir sürü yönetim sistemidir.',
} = Astro.props;
---

<!doctype html>
<html lang="tr" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://moo-tion.github.io" />

    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/mootion_logo_square.png" />
    <link rel="apple-touch-icon" href="/mootion_logo_square.png" />

    <!-- Preconnect for Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="min-h-screen overflow-x-hidden">
    <slot />
  </body>
</html>
